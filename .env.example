# ─────────────────────────────────────────────────────────────
#  Book Analytics Agent — Variáveis de Ambiente (EXEMPLO)
#  Copie este arquivo para .env e preencha com seus valores:
#    cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Chave da API Anthropic
# Obtenha em: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave da API OpenAI / ChatGPT
# Obtenha em: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pelo menos uma das chaves acima é obrigatória.
# O agente seleciona automaticamente o provider disponível.

# Provider padrão: openai | anthropic
# LLM_PROVIDER=openai

# Modelo do Claude (opcional — padrão: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Modelo da OpenAI (opcional — padrão: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Número máximo de iterações do agent por pergunta (opcional — padrão: 10)
# AGENT_MAX_ITERATIONS=6

# Tokens máximos de saída por resposta
# MAX_OUTPUT_TOKENS=4096

# Orçamento rápido de saída para reduzir latência percebida
# FAST_OUTPUT_TOKEN_BUDGET=1200

# Temperatura (analytics em produção costuma usar 0.0)
# AGENT_TEMPERATURE=0

# Logging / observabilidade
# LOG_LEVEL=INFO
# BRL_PER_USD=5.80

# Cache de queries SQL (segundos)
# QUERY_CACHE_TTL=300

# Guardrails
# GUARDRAILS=true

# Timeout por chamada de API (segundos)
# LLM_TIMEOUT_SECONDS=45
